generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("postgres://766befa48b1045432adf8f03b39e4e63d34ed945330884bf93c37edadc9fe8b6:sk_XPNj39L7QeFXEpRxg4PHy@db.prisma.io:5432/postgres?sslmode=require")
}

model Project {
  id        String   @id @default(cuid())
  name      String
  order     Int      @default(0)
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  tasks     Task[]
}

model Task {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title         String
  priority      String   @default("Medium") // High | Medium | Low
  dueDate       DateTime?
  column        String   @default("Todo")  // Todo | InProgress | Done
  orderInColumn Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
